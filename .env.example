# Banco de dados SQLite (local)
DATABASE_URL="file:./dev.db"

# Sua chave da API da Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# Senha compartilhada para o app
APP_PASSWORD="suasenha123"

# Segredo para sessão Next-Auth (gere um aleatório: openssl rand -base64 32)
NEXTAUTH_SECRET="seu-segredo-aqui"

# URL do app (em desenvolvimento: http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"
