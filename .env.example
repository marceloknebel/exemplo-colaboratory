# Banco de dados PostgreSQL (obtido no Vercel → Storage → Create Database)
DATABASE_URL="postgresql://..."

# Chave da API da Anthropic (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY="sk-ant-..."

# Senha compartilhada para entrar no app (você escolhe)
APP_PASSWORD="suasenha123"

# Segredo aleatório para sessões (gere em: https://generate-secret.vercel.app/32)
NEXTAUTH_SECRET="seu-segredo-aqui"
